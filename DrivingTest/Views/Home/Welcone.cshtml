@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bảng điều khiển - Thi Lái Xe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/heroicons@1.0.6/dist/tailwind.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9; /* Slate 100 */
        }
        
        /* Feedback Modal Styles */
        .modal {
            transition: opacity 0.3s ease;
        }
        
        .modal-backdrop {
            backdrop-filter: blur(4px);
        }
    </style>
</head>
<body class="bg-slate-100">

    <header class="bg-white shadow-md py-4 sticky top-0 w-full z-50">
        <div class="container mx-auto px-6 flex justify-between items-center">
            <a href="#" class="text-3xl font-extrabold text-blue-600">Thi Lái Xe</a>

            <div class="flex items-center space-x-4">
                <a asp-controller="Home" asp-action="UserProfile" class="flex items-center text-gray-700 hover:text-blue-600 transition duration-300 group">
                    <span class="font-semibold mr-3">Chào, @User.Identity.Name</span>
                    <div class="w-10 h-10 bg-blue-200 rounded-full flex items-center justify-center group-hover:ring-2 group-hover:ring-blue-400 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </div>
                </a>
                <a asp-controller="Authenticator" asp-action="Logout"
                   class="text-gray-500 hover:text-red-500" title="Đăng xuất">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                </a>

            </div>
        </div>
    </header>

    <main class="container mx-auto px-6 py-12">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg animate-pulse">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg animate-pulse">
                @TempData["ErrorMessage"]
            </div>
        }
        
        <h1 class="text-4xl font-bold text-gray-800 mb-4">Bắt đầu hành trình của bạn</h1>
        <p class="text-lg text-gray-600 mb-12">Chọn một chế độ để ôn luyện và chuẩn bị cho kỳ thi sát hạch.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <a asp-controller="TestManagement" asp-action="PracticeTest" class="group block bg-white rounded-2xl shadow-lg p-8 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
                <div class="flex items-center mb-4">
                    <div class="bg-blue-100 text-blue-600 rounded-xl p-4 mr-6">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v11.494m-9-5.747h18" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-3xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors">Luyện tập</h2>
                        <p class="text-gray-500">Ôn tập theo từng chuyên đề</p>
                    </div>
                </div>
                <p class="text-gray-600">Củng cố kiến thức với các bộ câu hỏi được phân loại theo từng chủ đề như biển báo, sa hình, luật giao thông...</p>
            </a>

            <a asp-controller="TestManagement" asp-action="SelectTest" class="group block bg-white rounded-2xl shadow-lg p-8 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
                <div class="flex items-center mb-4">
                    <div class="bg-green-100 text-green-600 rounded-xl p-4 mr-6">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-3xl font-bold text-gray-900 group-hover:text-green-600 transition-colors">Thi thử</h2>
                        <p class="text-gray-500">Làm bài thi ngẫu nhiên</p>
                    </div>
                </div>
                <p class="text-gray-600">Thử sức với các bộ đề thi ngẫu nhiên có cấu trúc và giới hạn thời gian như thi thật để làm quen với áp lực.</p>
            </a>
        </div>

        <div class="mt-20">
            <h3 class="text-2xl font-bold text-center text-gray-800 mb-8">Nội dung ôn tập đa dạng</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

                <a asp-controller="TestManagement" asp-action="Index" asp-route-category="Biển báo" class="relative rounded-xl overflow-hidden shadow-lg block">
                    <img src="https://placehold.co/600x400/3b82f6/ffffff?text=Bi%E1%BB%83n+B%C3%A1o" alt="Biển báo giao thông" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black bg-opacity-40 flex items-end p-6">
                        <h4 class="text-white text-2xl font-bold">Biển báo</h4>
                    </div>
                </a>

                <a asp-controller="TestManagement" asp-action="Index" asp-route-category="Sa hình" class="relative rounded-xl overflow-hidden shadow-lg block">
                    <img src="https://placehold.co/600x400/10b981/ffffff?text=Sa+H%C3%ACnh" alt="Sa hình" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black bg-opacity-40 flex items-end p-6">
                        <h4 class="text-white text-2xl font-bold">Sa hình</h4>
                    </div>
                </a>

                <a asp-controller="TestManagement" asp-action="Index" asp-route-category="Luật giao thông" class="relative rounded-xl overflow-hidden shadow-lg block">
                    <img src="https://placehold.co/600x400/f59e0b/ffffff?text=L%C3%BD+Thuy%E1%BA%BFt" alt="Lý thuyết luật giao thông" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black bg-opacity-40 flex items-end p-6">
                        <h4 class="text-white text-2xl font-bold">Luật giao thông</h4>
                    </div>
                </a>

            </div>
        </div>

        <!-- Section Feedback -->
        <div class="mt-20">
            <div class="bg-gradient-to-r from-blue-500 to-cyan-500 rounded-3xl shadow-2xl overflow-hidden">
                <div class="px-8 py-12 md:px-16">
                    <div class="flex flex-col md:flex-row items-center justify-between">
                        <div class="mb-8 md:mb-0 md:mr-12 text-center md:text-left">
                            <h3 class="text-3xl md:text-4xl font-bold text-white mb-4">
                                Có góp ý hay câu hỏi?
                            </h3>
                            <p class="text-blue-100 text-lg">
                                Chúng tôi luôn lắng nghe và sẵn sàng hỗ trợ bạn. Gửi phản hồi để giúp chúng tôi cải thiện dịch vụ!
                            </p>
                        </div>
                        <button onclick="openFeedbackModal()" 
                                class="px-8 py-4 bg-white text-blue-600 rounded-full font-bold text-lg hover:bg-blue-50 transform hover:scale-105 transition-all duration-300 shadow-xl hover:shadow-2xl flex items-center space-x-2 whitespace-nowrap">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                            </svg>
                            <span>Gửi phản hồi</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- Feedback Modal -->
    <div id="feedbackModal" class="modal fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 modal-backdrop" onclick="closeFeedbackModal(event)">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-2xl mx-4 md:mx-auto transform transition-all" onclick="event.stopPropagation()">
            <div class="bg-gradient-to-r from-blue-600 to-cyan-500 p-6 rounded-t-3xl">
                <div class="flex justify-between items-center">
                    <h3 class="text-2xl md:text-3xl font-bold text-white">Gửi phản hồi</h3>
                    <button onclick="closeFeedbackModal()" class="text-white hover:text-gray-200 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            
            <form asp-controller="Home" asp-action="SubmitFeedback" method="post" class="p-8">
                @Html.AntiForgeryToken()
                
                <div class="mb-6">
                    <label class="block text-gray-700 font-bold mb-3 text-lg" for="feedbackTitle">
                        Tiêu đề
                    </label>
                    <input type="text" 
                           id="feedbackTitle" 
                           name="Title" 
                           required
                           maxlength="200"
                           class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-200 focus:border-blue-500 transition-all text-base"
                           placeholder="Nhập tiêu đề phản hồi của bạn...">
                </div>
                
                <div class="mb-6">
                    <label class="block text-gray-700 font-bold mb-3 text-lg" for="feedbackMessage">
                        Nội dung
                    </label>
                    <textarea id="feedbackMessage" 
                              name="Message" 
                              required
                              rows="6"
                              maxlength="1000"
                              class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-200 focus:border-blue-500 transition-all resize-none text-base"
                              placeholder="Chia sẻ ý kiến, đề xuất hoặc báo cáo lỗi của bạn..."></textarea>
                    <p class="text-sm text-gray-500 mt-2">Tối đa 1000 ký tự</p>
                </div>
                
                <div class="flex flex-col-reverse sm:flex-row justify-end gap-4">
                    <button type="button" 
                            onclick="closeFeedbackModal()"
                            class="px-6 py-3 border-2 border-gray-300 text-gray-700 rounded-full font-bold hover:bg-gray-100 transition-all duration-300">
                        Hủy
                    </button>
                    <button type="submit"
                            class="px-8 py-3 bg-gradient-to-r from-blue-600 to-cyan-500 text-white rounded-full font-bold hover:from-blue-700 hover:to-cyan-600 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl">
                        Gửi phản hồi
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-400 mt-16">
        <div class="container mx-auto px-6 py-8 text-center">
            <p>&copy; 2024 Thi bằng lái xe trực tuyến. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        function openFeedbackModal() {
            const modal = document.getElementById('feedbackModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }

        function closeFeedbackModal(event) {
            if (event && event.target.id !== 'feedbackModal') {
                return;
            }
            const modal = document.getElementById('feedbackModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = 'auto';
            
            document.getElementById('feedbackTitle').value = '';
            document.getElementById('feedbackMessage').value = '';
        }

        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeFeedbackModal();
            }
        });
    </script>

</body>
</html>
