@using DrivingTest.Models
@model DrivingTest.ViewModels.MockTestViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thi thử Hạng @Model.Category - Thi Lái Xe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .answer-btn:hover { background-color: #e0f2fe; border-color: #38bdf8; }
        .answer-btn.selected { background-color: #bae6fd; border-color: #0ea5e9; color: #0c4a6e; font-weight: 600; }
        .timer-warning { animation: pulse 1.5s infinite; }
      @@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

        .nav-grid-btn { transition: all 0.2s ease; }
        .nav-grid-btn.answered { background-color: #dcfce7; color: #166534; border-color: #4ade80; }
        .nav-grid-btn.current { background-color: #3b82f6; color: white; border-color: #2563eb; transform: scale(1.1); }
    </style>
</head>
<body class="bg-slate-50">

    <div class="flex flex-col lg:flex-row max-w-7xl mx-auto p-4 gap-6">

        <!-- Left Panel -->
        <main class="w-full lg:w-2/3 bg-white rounded-2xl shadow-lg p-6 md:p-8">
            <div id="question-card-container"></div>
        </main>

        <!-- Right Panel -->
        <aside class="w-full lg:w-1/3">
            <div class="sticky top-4 space-y-6">
                <!-- Timer -->
                <div class="bg-white rounded-2xl shadow-lg p-4">
                    <h2 class="text-center font-bold text-gray-700 mb-2">THỜI GIAN CÒN LẠI</h2>
                    <div id="timer-container" class="flex items-center justify-center space-x-2 bg-gray-100 text-gray-800 font-bold px-4 py-2 rounded-lg transition-colors duration-500">
                        <span id="timer" class="text-2xl tracking-wider">@Model.TestDurationInMinutes:00</span>
                    </div>
                </div>

                <!-- Nav Grid -->
                <div class="bg-white rounded-2xl shadow-lg p-4">
                    <h2 class="text-center font-bold text-gray-700 mb-4">DANH SÁCH CÂU HỎI</h2>
                    <div id="question-grid" class="grid grid-cols-5 gap-3"></div>
                </div>
                
                <!-- Submit -->
                <button id="submit-btn" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-6 rounded-full shadow-xl transition duration-300 text-lg">
                    NỘP BÀI
                </button>
            </div>
        </aside>
    </div>
    
    <!-- Modal -->
    <div id="modal" class="fixed inset-0 bg-black bg-opacity-60 flex items-center justify-center p-4 z-50 hidden">
        <div id="modal-content" class="bg-white rounded-2xl shadow-2xl p-8 max-w-sm w-full text-center transform transition-all scale-95 opacity-0"></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const questions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Questions.Select(q => new {
                    id = q.QuestionId,
                    text = q.QuestionText,
                    imageUrl = q.ImageUrl,
                    answers = q.Answers.Select(a => new { key = a.OptionKey, text = a.OptionText }),
                    correctAnswer = q.CorrectAnswer
                })
            ));

            const testDurationMinutes = @Model.TestDurationInMinutes;
            const passingScore = @Model.PassingScore;

            let currentQuestionIndex = 0;
            let userAnswers = {};
            let timerInterval;

            const timerEl = document.getElementById('timer');
            const timerContainer = document.getElementById('timer-container');
            const questionContainer = document.getElementById('question-card-container');
            const questionGrid = document.getElementById('question-grid');
            const submitBtn = document.getElementById('submit-btn');
            const modal = document.getElementById('modal');
            const modalContent = document.getElementById('modal-content');

            function renderNavGrid() {
                questionGrid.innerHTML = '';
                questions.forEach((_, index) => {
                    const btn = document.createElement('button');
                    btn.className = 'nav-grid-btn border-2 rounded-lg font-semibold p-2';
                    btn.textContent = index + 1;
                    btn.onclick = () => loadQuestion(index);
                    questionGrid.appendChild(btn);
                });
            }

            function updateNavGridState() {
                [...questionGrid.children].forEach((btn, i) => {
                    btn.classList.remove('current', 'answered');
                    if (userAnswers[questions[i].id]) btn.classList.add('answered');
                    if (i === currentQuestionIndex) btn.classList.add('current');
                });
            }

            function loadQuestion(index) {
                currentQuestionIndex = index;
                const q = questions[index];
                const answersHtml = q.answers.map(a => `
                    <button class="answer-btn w-full text-left p-4 border-2 rounded-lg flex items-center ${userAnswers[q.id] === a.key ? 'selected' : ''}" data-key="${a.key}">
                        <span class="font-bold mr-4">${a.key}.</span>
                        <span>${a.text}</span>
                    </button>
                `).join("");

                const imageHtml = q.imageUrl ? `<div class="mb-4"><img src="${q.imageUrl}" class="max-w-sm mx-auto rounded-lg shadow-md"></div>` : "";

                questionContainer.innerHTML = `
                    <h2 class="text-xl font-bold text-blue-600 mb-6">Câu hỏi ${index+1}/${questions.length}</h2>
                    ${imageHtml}
                    <p class="text-lg text-gray-800 mb-6">${q.text}</p>
                    <div class="space-y-4">${answersHtml}</div>
                `;

                questionContainer.querySelectorAll('.answer-btn').forEach(btn => {
                    btn.onclick = () => {
                        userAnswers[q.id] = btn.dataset.key;
                        loadQuestion(index);
                        updateNavGridState();
                    };
                });

                updateNavGridState();
            }

            function showModal(content) {
                modalContent.innerHTML = content;
                modal.classList.remove('hidden');
                setTimeout(() => modalContent.classList.add('scale-100','opacity-100'), 10);
            }

            function handleSubmit() {
                let score = 0;
                questions.forEach(q => { if (userAnswers[q.id] === q.correctAnswer) score++; });
                const isPass = score >= passingScore;

               showModal(`
  <div class="flex flex-col items-center space-y-4"> <!-- Thêm flex và space-y-4 để các phần tử cách nhau -->
    <h2 class="text-3xl font-bold ${isPass ? 'text-green-600':'text-red-600'}">${isPass ? 'ĐẠT':'KHÔNG ĐẠT'}</h2>
    
    <p class="text-lg text-gray-600">Bạn đúng <span class="font-extrabold text-gray-800">${score}/${questions.length}</span></p>
    
    <a href="@Url.Action("MockTest","TestManagement", new { category = Model.Category })" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-full text-center w-full max-w-xs">
      Thi lại
    </a>

    <a href="@Url.Action("Welcone","Home", new { category = Model.Category })" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-full text-center w-full max-w-xs">
      Kết Thúc
    </a>
  </div>
`);
clearInterval(timerInterval);

            }

            function startTimer() {
                let time = testDurationMinutes * 60;
                timerInterval = setInterval(() => {
                    time--;
                    const m = Math.floor(time/60), s = time%60;
                    timerEl.textContent = `${m}:${s<10?'0':''}${s}`;
                    if (time<=0){ clearInterval(timerInterval); handleSubmit(); }
                }, 1000);
            }

            renderNavGrid();
            loadQuestion(0);
            startTimer();
            submitBtn.onclick = handleSubmit;
        });
    </script>
</body>
</html>
