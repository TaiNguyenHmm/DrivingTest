@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chọn Hạng Bằng Thi Thử</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f1f5f9; /* Slate 100 */
        }
    </style>
</head>
<body class="bg-slate-100">

    <div class="container mx-auto p-4 md:p-8 max-w-5xl">
        <!-- Header -->
        <header class="text-center mb-12">
            <a asp-action="Welcone" asp-controller="Home" class="text-gray-600 hover:text-blue-600 inline-flex items-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Quay lại Bảng điều khiển
            </a>
            <h1 class="text-4xl font-extrabold text-gray-800">Chọn Hạng Bằng Thi Thử</h1>
            <p class="text-lg text-gray-600 mt-2">Lựa chọn bộ đề thi phù hợp với hạng bằng của bạn.</p>
        </header>

        <!-- License Category Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">

            <!-- Card B1, B11 -->
            <div class="bg-white rounded-2xl shadow-lg p-6 flex flex-col text-center items-center transform hover:-translate-y-2 transition-transform duration-300">
                <div class="bg-blue-100 text-blue-600 rounded-full h-16 w-16 flex items-center justify-center mb-4">
                    <span class="text-2xl font-bold">B1</span>
                </div>
                <h2 class="text-2xl font-bold text-gray-800">Hạng B1, B11</h2>
                <div class="my-4 text-gray-600 space-y-1">
                    <p><strong>30</strong> câu hỏi</p>
                    <p><strong>20</strong> phút</p>
                    <p>Điểm cần đạt: <strong>27/30</strong></p>
                </div>
                <a asp-controller="TestManagement" asp-action="MockTest" asp-route-category="B1-B11" class="mt-auto w-full bg-blue-600 text-white font-bold py-3 px-6 rounded-full shadow-lg hover:bg-blue-700 transition duration-300">
                    Bắt đầu thi
                </a>
            </div>

            <!-- Card B2 -->
            <div class="bg-white rounded-2xl shadow-lg p-6 flex flex-col text-center items-center transform hover:-translate-y-2 transition-transform duration-300">
                <div class="bg-green-100 text-green-600 rounded-full h-16 w-16 flex items-center justify-center mb-4">
                    <span class="text-2xl font-bold">B2</span>
                </div>
                <h2 class="text-2xl font-bold text-gray-800">Hạng B2</h2>
                <div class="my-4 text-gray-600 space-y-1">
                    <p><strong>35</strong> câu hỏi</p>
                    <p><strong>22</strong> phút</p>
                    <p>Điểm cần đạt: <strong>32/35</strong></p>
                </div>
                <a asp-controller="TestManagement" asp-action="MockTest" asp-route-category="B2" class="mt-auto w-full bg-green-600 text-white font-bold py-3 px-6 rounded-full shadow-lg hover:bg-green-700 transition duration-300">
                    Bắt đầu thi
                </a>
            </div>

            <!-- Card C -->
            <div class="bg-white rounded-2xl shadow-lg p-6 flex flex-col text-center items-center transform hover:-translate-y-2 transition-transform duration-300">
                <div class="bg-yellow-100 text-yellow-600 rounded-full h-16 w-16 flex items-center justify-center mb-4">
                    <span class="text-2xl font-bold">C</span>
                </div>
                <h2 class="text-2xl font-bold text-gray-800">Hạng C</h2>
                <div class="my-4 text-gray-600 space-y-1">
                    <p><strong>40</strong> câu hỏi</p>
                    <p><strong>24</strong> phút</p>
                    <p>Điểm cần  đạt: <strong>36/40</strong></p>
                </div>
                <a asp-controller="TestManagement" asp-action="MockTest" asp-route-category="C" class="mt-auto w-full bg-yellow-600 text-white font-bold py-3 px-6 rounded-full shadow-lg hover:bg-yellow-700 transition duration-300">
                    Bắt đầu thi
                </a>
            </div>

            <!-- Card D, E, F -->
            <div class="bg-white rounded-2xl shadow-lg p-6 flex flex-col text-center items-center transform hover:-translate-y-2 transition-transform duration-300">
                <div class="bg-red-100 text-red-600 rounded-full h-16 w-16 flex items-center justify-center mb-4">
                    <span class="text-2xl font-bold">D</span>
                </div>
                <h2 class="text-2xl font-bold text-gray-800">Hạng D, E, F</h2>
                <div class="my-4 text-gray-600 space-y-1">
                    <p><strong>45</strong> câu hỏi</p>
                    <p><strong>26</strong> phút</p>
                    <p>Điểm cần đạt: <strong>41/45</strong></p>
                </div>
                <a asp-controller="TestManagement" asp-action="MockTest" asp-route-category="D-E-F" class="mt-auto w-full bg-red-600 text-white font-bold py-3 px-6 rounded-full shadow-lg hover:bg-red-700 transition duration-300">
                    Bắt đầu thi
                </a>
            </div>

        </div>
    </div>
</body>
</html>
