@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model DrivingTest.ViewModels.EditQuestionViewModel

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa câu hỏi</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        inter: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        'primary-blue': '#3b82f6',
                        'primary-cyan': '#06b6d4',
                    },
                    animation: {
                        'fadeIn': 'fadeIn 0.5s ease-in-out',
                        'slideUp': 'slideUp 0.4s ease-out',
                        'scaleIn': 'scaleIn 0.3s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        },
                        scaleIn: {
                            '0%': { transform: 'scale(0.95)', opacity: '0' },
                            '100%': { transform: 'scale(1)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        
        input[type="radio"] {
            appearance: none;
            width: 1.5rem;
            height: 1.5rem;
            border: 2px solid #d1d5db;
            border-radius: 50%;
            outline: none;
            cursor: pointer;
            position: relative;
            transition: all 0.3s ease;
        }
        
        input[type="radio"]:hover {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
        
        input[type="radio"]:checked {
            border-color: #3b82f6;
            background-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.2);
        }
        
        input[type="radio"]:checked::before {
            content: '';
            position: absolute;
            width: 0.5rem;
            height: 0.5rem;
            background: white;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        input, textarea {
            transition: all 0.3s ease;
        }

        .answer-option {
            transition: all 0.3s ease;
        }

        .answer-option:hover {
            transform: translateX(4px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        .answer-option.selected {
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            border: 2px solid #3b82f6;
            box-shadow: 0 10px 30px -5px rgba(59, 130, 246, 0.3);
        }

        .image-preview {
            transition: all 0.3s ease;
        }

        .image-preview:hover {
            transform: scale(1.02);
            box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.2);
        }

        .btn-gradient {
            background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
            transition: all 0.3s ease;
        }

        .btn-gradient:hover {
            background: linear-gradient(135deg, #2563eb 0%, #0891b2 100%);
            box-shadow: 0 15px 35px -5px rgba(59, 130, 246, 0.4);
            transform: translateY(-2px);
        }

        .btn-gradient:active {
            transform: translateY(0);
        }
    </style>
</head>
<body class="font-inter antialiased bg-gradient-to-br from-slate-50 via-blue-50 to-cyan-50 min-h-screen py-8 px-4 sm:px-6 lg:px-8">

    <div class="w-full max-w-4xl mx-auto animate-fadeIn">
        <!-- Card Container -->
        <div class="bg-white/90 backdrop-blur-sm p-8 md:p-12 rounded-3xl shadow-2xl border border-gray-200/50 animate-scaleIn">
            
            <!-- Header -->
            <div class="text-center mb-10 animate-slideUp">
                <div class="inline-block mb-4">
                    <div class="w-16 h-16 mx-auto bg-gradient-to-br from-blue-500 to-cyan-500 rounded-2xl flex items-center justify-center shadow-lg">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                    </div>
                </div>
                <h2 class="text-4xl md:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-blue-500 to-cyan-500 mb-3">
                    Sửa câu hỏi
                </h2>
                <p class="text-gray-600 text-lg">Cập nhật thông tin chi tiết cho câu hỏi thi sát hạch</p>
            </div>

            <form asp-action="EditQuestion" 
                  asp-controller="Dashboard" 
                  asp-route-id="@Model.QuestionId" 
                  method="post" 
                  enctype="multipart/form-data"
                  class="space-y-8">
                
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="QuestionId" />

                <div class="space-y-3">
                    <label asp-for="QuestionText" class="flex items-center text-gray-800 font-bold text-lg">
                        <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Nội dung câu hỏi
                    </label>
                    <textarea asp-for="QuestionText"
                              rows="5"
                              class="w-full bg-white border-2 border-gray-300 rounded-2xl p-5 text-gray-900 text-base leading-relaxed focus:ring-4 focus:ring-blue-200 focus:border-blue-500 focus:outline-none shadow-sm hover:border-gray-400"
                              placeholder="Nhập nội dung câu hỏi..."
                              required></textarea>
                    <span asp-validation-for="QuestionText" class="text-red-500 text-sm font-medium"></span>
                </div>

                <div class="space-y-4">
                    <label class="flex items-center text-gray-800 font-bold text-lg">
                        <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        Ảnh minh họa
                    </label>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="bg-gradient-to-br from-blue-50 to-cyan-50 p-6 rounded-2xl border-2 border-blue-200">
                            <p class="text-sm font-semibold text-gray-600 mb-3 uppercase tracking-wider">Ảnh hiện tại</p>
                            <img src="@Url.Content(Model.ImageUrl)"
                                 alt="Ảnh minh họa hiện tại"
                                 class="w-full max-w-md mx-auto h-auto rounded-xl shadow-lg border-2 border-white image-preview" />
                        </div>
                    }

                    <div class="relative">
                        <input type="file"
                               asp-for="ImageFile"
                               class="w-full text-gray-700 text-base bg-white border-2 border-dashed border-gray-300 rounded-2xl p-4 hover:border-blue-400 transition-all file:mr-4 file:py-3 file:px-6 file:rounded-xl file:border-0 file:text-base file:font-bold file:bg-gradient-to-r file:from-blue-600 file:to-cyan-500 file:text-white hover:file:from-blue-700 hover:file:to-cyan-600 file:transition-all file:duration-300 file:cursor-pointer file:shadow-md hover:file:shadow-lg"
                               accept="image/*" />
                        <p class="mt-2 text-sm text-gray-500 italic">Chọn ảnh mới nếu muốn thay đổi (PNG, JPG, JPEG)</p>
                    </div>
                </div>

                <div class="space-y-5">
                    <label class="flex items-center text-gray-800 font-bold text-lg">
                        <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Các đáp án
                        <span class="ml-2 text-sm font-normal text-gray-500">(Chọn đáp án đúng)</span>
                    </label>

                    <div class="answer-option @(Model.CorrectOption == "A" ? "selected" : "") flex items-center space-x-4 bg-white p-5 rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-lg">
                        <input type="radio" asp-for="CorrectOption" value="A" />
                        <label class="font-bold text-xl text-gray-700 min-w-[2rem] @(Model.CorrectOption == "A" ? "text-blue-600" : "")">A</label>
                        <input type="text"
                               asp-for="OptionA"
                               placeholder="Nhập đáp án A"
                               class="flex-1 p-4 border-2 border-gray-300 rounded-xl focus:ring-4 focus:ring-blue-200 focus:border-blue-500 focus:outline-none text-base bg-gray-50 hover:bg-white transition-all"
                               required />
                    </div>

                    <div class="answer-option @(Model.CorrectOption == "B" ? "selected" : "") flex items-center space-x-4 bg-white p-5 rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-lg">
                        <input type="radio" asp-for="CorrectOption" value="B" />
                        <label class="font-bold text-xl text-gray-700 min-w-[2rem] @(Model.CorrectOption == "B" ? "text-blue-600" : "")">B</label>
                        <input type="text"
                               asp-for="OptionB"
                               placeholder="Nhập đáp án B"
                               class="flex-1 p-4 border-2 border-gray-300 rounded-xl focus:ring-4 focus:ring-blue-200 focus:border-blue-500 focus:outline-none text-base bg-gray-50 hover:bg-white transition-all"
                               required />
                    </div>

                    <div class="answer-option @(Model.CorrectOption == "C" ? "selected" : "") flex items-center space-x-4 bg-white p-5 rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-lg">
                        <input type="radio" asp-for="CorrectOption" value="C" />
                        <label class="font-bold text-xl text-gray-700 min-w-[2rem] @(Model.CorrectOption == "C" ? "text-blue-600" : "")">C</label>
                        <input type="text"
                               asp-for="OptionC"
                               placeholder="Nhập đáp án C (tùy chọn)"
                               class="flex-1 p-4 border-2 border-gray-300 rounded-xl focus:ring-4 focus:ring-blue-200 focus:border-blue-500 focus:outline-none text-base bg-gray-50 hover:bg-white transition-all" />
                    </div>

                    <div class="answer-option @(Model.CorrectOption == "D" ? "selected" : "") flex items-center space-x-4 bg-white p-5 rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-lg">
                        <input type="radio" asp-for="CorrectOption" value="D" />
                        <label class="font-bold text-xl text-gray-700 min-w-[2rem] @(Model.CorrectOption == "D" ? "text-blue-600" : "")">D</label>
                        <input type="text"
                               asp-for="OptionD"
                               placeholder="Nhập đáp án D (tùy chọn)"
                               class="flex-1 p-4 border-2 border-gray-300 rounded-xl focus:ring-4 focus:ring-blue-200 focus:border-blue-500 focus:outline-none text-base bg-gray-50 hover:bg-white transition-all" />
                    </div>

                    <span asp-validation-for="CorrectOption" class="text-red-500 text-sm font-medium block mt-2"></span>
                </div>

                <div class="flex flex-col-reverse sm:flex-row justify-end items-center gap-4 pt-8 border-t-2 border-gray-100">
                    <button type="button"
                            onclick="history.back()"
                            class="w-full sm:w-auto px-8 py-4 rounded-full text-gray-700 font-bold text-base border-2 border-gray-300 hover:border-blue-500 hover:text-blue-600 hover:bg-blue-50 transition-all duration-300 transform hover:scale-105 shadow-md hover:shadow-lg">
                        <span class="inline-flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                            </svg>
                            Hủy bỏ
                        </span>
                    </button>
                    <button type="submit"
                            class="w-full sm:w-auto px-8 py-4 rounded-full font-bold text-base text-white btn-gradient shadow-xl">
                        <span class="inline-flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            Lưu thay đổi
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.querySelectorAll('input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function() {
                // Remove selected class from all answer options
                document.querySelectorAll('.answer-option').forEach(opt => {
                    opt.classList.remove('selected');
                });
                
                // Add selected class to parent answer option
                const parent = this.closest('.answer-option');
                if (parent) {
                    parent.classList.add('selected');
                    
                    // Smooth scroll to show the selected option
                    parent.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
            });
        });

        // Image preview on file select
        document.querySelector('input[type="file"]').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    // You could add a preview here if needed
                    console.log('Image selected:', file.name);
                };
                reader.readAsDataURL(file);
            }
        });

        // Form validation enhancement
        document.querySelector('form').addEventListener('submit', function(e) {
            const questionText = document.querySelector('textarea[name="QuestionText"]').value.trim();
            const optionA = document.querySelector('input[name="OptionA"]').value.trim();
            const optionB = document.querySelector('input[name="OptionB"]').value.trim();
            const correctOption = document.querySelector('input[name="CorrectOption"]:checked');

            if (!questionText || !optionA || !optionB || !correctOption) {
                e.preventDefault();
                alert('Vui lòng điền đầy đủ thông tin câu hỏi, ít nhất 2 đáp án A và B, và chọn đáp án đúng!');
                return false;
            }
        });
    </script>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>